# Set default behavior to automatically guess encoding.
* text=auto

# Ensure bash scripts use LF line endings
*.sh text eol=lf

# Ensure batch files use CRLF line endings
*.bat text eol=crlf

# Denote all files that are truly binary and should not be modified.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.wav binary
*.pyc binary
